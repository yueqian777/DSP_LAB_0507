#include "user_equalizer_display.h"

#include <stdio.h>
#include <string.h>

static int require_true(int condition, const char *message)
{
    if (!condition)
    {
        printf("equalizer_lcd_alignment FAIL: %s\n", message);
        return 1;
    }
    return 0;
}

int main(void)
{
    EQ_UI_SNAPSHOT snapshot;
    unsigned long primitives;
    int failures;

    failures = 0;
    memset(&snapshot, 0, sizeof(snapshot));
    EqualizerDisplay_Init();
    failures += require_true(EQ_DebugLcdAlignmentPatternEnabled == 1U,
                             "alignment profile marker");
    failures += require_true(EQ_DebugLcdRuntimeMask == 0U,
                             "runtime mask forced off");
    failures += require_true(EqualizerDisplay_DrawStaticLayout() == 1,
                             "static alignment draw");
    primitives = EqualizerDisplay_TestPrimitiveCount();
    failures += require_true(primitives == 37UL,
                             "complete alignment primitive set");
    failures += require_true(EQ_DebugLcdBoundsFailureCount == 0UL,
                             "alignment bounds");
    failures += require_true(
        EQ_DebugLcdFramebufferCanaryCheckCount == 1UL,
        "post-layout hardware audit");
    failures += require_true(EQ_DebugLcdFaultLatched == 0U,
                             "healthy alignment audit");
    EqualizerDisplay_BeginRuntime();
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_RequestSnapshot(&snapshot, 1UL);
    failures += require_true(EQ_DebugLcdRuntimeMask == 0U,
                             "runtime mask remains forced off");
    failures += require_true(!EqualizerDisplay_HasPendingJob(),
                             "alignment page remains static");
    failures += require_true(EQ_DebugLcdPendingMask == 0UL,
                             "alignment has no runtime jobs");
    failures += require_true(EqualizerDisplay_ServiceOneJob(2UL) ==
                             EQ_LCD_JOB_NONE,
                             "alignment service has no runtime draw");
    failures += require_true(EqualizerDisplay_TestPrimitiveCount() ==
                             primitives && EQ_DebugLcdJobCount == 0UL,
                             "runtime leaves static framebuffer unchanged");
    EqualizerDisplay_AuditHardware(256UL, 0);
    failures += require_true(
        EQ_DebugLcdFramebufferCanaryCheckCount == 2UL,
        "periodic static framebuffer guard");

    printf("equalizer_lcd_alignment failures=%d\n", failures);
    return (failures == 0) ? 0 : 1;
}
