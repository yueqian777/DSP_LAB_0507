#include <assert.h>

#include "grlib.h"
#include "user_subband_ui_logic.h"

static int ChainWidth(const tFont *font, const char *text)
{
    unsigned int character;
    int width;

    width = 0;
    while (*text != '\0')
    {
        character = (unsigned int)(unsigned char)*text++;
        if ((character < 32U) || (character > 126U))
        {
            character = (unsigned int)'?';
        }
        width += font->pucData[font->pusOffset[character - 32U]];
    }
    return width;
}

int main(void)
{
    static const int modes[8] = {0, 1, 2, 4, 6, 7, 8, 11};
    static const int rates[3] = {160, 240, 320};
    char chain[96];
    int fallback_count;
    int width_18b;
    int width_fallback;
    unsigned int mode_index;
    unsigned int rate_index;

    fallback_count = 0;
    for (mode_index = 0U; mode_index < 8U; mode_index++)
    {
        for (rate_index = 0U; rate_index < 3U; rate_index++)
        {
            assert(SubbandUI_BuildProcessingChain(chain, sizeof(chain),
                                                  modes[mode_index],
                                                  rates[rate_index]) == 1);
            width_18b = ChainWidth(&g_sFontCmss18b, chain);
            width_fallback = ChainWidth(&g_sFontCmtt12, chain);
            if (width_18b > (770 - 28))
            {
                fallback_count++;
            }
            assert((width_18b <= (770 - 28)) ||
                   (width_fallback <= (770 - 28)));
        }
    }
    assert(fallback_count > 0);
    assert(GrFontHeightGet(&g_sFontCmss18b) <= (106 - 80));
    assert(GrFontHeightGet(&g_sFontCmtt12) <= (106 - 80));
    return 0;
}
