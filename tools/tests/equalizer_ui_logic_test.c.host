#include "user_equalizer_ui_logic.h"

#include <stdio.h>
#include <string.h>

#define JOB_BIT(job_) (1UL << ((job_) - 1))

static int require_true(int condition, const char *message)
{
    if (!condition)
    {
        printf("equalizer_ui_logic FAIL: %s\n", message);
        return 1;
    }
    return 0;
}

static void make_snapshot(EQ_UI_SNAPSHOT *snapshot)
{
    int band;

    memset(snapshot, 0, sizeof(*snapshot));
    snapshot->applied_preset = EQ_PRESET_FLAT;
    snapshot->smart_strength = 2;
    snapshot->clarity_strength = 2;
    snapshot->guard_strength = 2;
    snapshot->analyzer_valid = 1;
    snapshot->analyzer_warm = 1;
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    snapshot->page = EQ_UI_PAGE_DYNAMIC_STATUS;
    snapshot->editor_selected_band = 0;
    snapshot->editor_apply_status = EQ_UI_APPLY_APPLIED;
    snapshot->editor_submitted_valid = 1U;
#endif
    for (band = 0; band < EQ_UI_ANALYZER_COUNT; band++)
    {
        snapshot->band_pixel[band] = EQ_UI_ANALYZER_ZERO_PIXEL;
    }
}

static unsigned int first_dynamic_field(unsigned int fields)
{
    if ((fields & EQ_UI_DYNAMIC_FIELD_ENABLED) != 0U)
        return EQ_UI_DYNAMIC_FIELD_ENABLED;
    if ((fields & EQ_UI_DYNAMIC_FIELD_STRENGTH) != 0U)
        return EQ_UI_DYNAMIC_FIELD_STRENGTH;
    return fields & EQ_UI_DYNAMIC_FIELD_LEVEL;
}

static void complete_one(EQ_UI_STATE *state, int job,
                         unsigned long frame)
{
    int index;
    unsigned int field;

    if ((job >= EQ_UI_JOB_DYNAMIC_0) &&
        (job <= EQ_UI_JOB_DYNAMIC_2))
    {
        index = job - EQ_UI_JOB_DYNAMIC_0;
        field = first_dynamic_field(
            EqualizerUiLogic_DynamicFieldMask(state, index));
        EqualizerUiLogic_CompleteDynamicField(state, job, field, frame);
    }
    else if ((job >= EQ_UI_JOB_ANALYZER_0) &&
             (job <= EQ_UI_JOB_ANALYZER_3))
    {
        index = job - EQ_UI_JOB_ANALYZER_0;
        field = EqualizerUiLogic_AnalyzerNextField(state, index);
        EqualizerUiLogic_CompleteAnalyzerField(state, job, field, frame);
    }
    else
    {
        EqualizerUiLogic_CompleteJob(state, job, frame);
    }
}

static int flush_jobs(EQ_UI_STATE *state, unsigned long first_frame)
{
    unsigned long offset;
    int completed;
    int job;

    completed = 0;
    for (offset = 0UL; offset < 4096UL; offset++)
    {
        if (!EqualizerUiLogic_HasPending(state))
        {
            return completed;
        }
        job = EqualizerUiLogic_SelectJob(state, first_frame + offset);
        if (job != EQ_UI_JOB_NONE)
        {
            complete_one(state, job, first_frame + offset);
            completed++;
        }
    }
    return -1;
}

static int test_layout_and_touch(void)
{
    EQ_UI_TOUCH_TRANSFORM transform;
    EQ_UI_TOUCH_STATE touch;
    int failures;
    int action;
    int rejected;
    int pixel;
    int x;
    int y;
    int i;

    failures = 0;
    failures += require_true(EqualizerUi_ValidateLayout(), "layout");
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += require_true(
        EQ_UI_PAGE_SWITCH_RECT.x == 672 &&
        EQ_UI_PAGE_SWITCH_RECT.y == 430 &&
        EQ_UI_PAGE_SWITCH_RECT.w == 104 &&
        EQ_UI_PAGE_SWITCH_RECT.h == 40,
        "page switch uses fixed bottom-right geometry");
    failures += require_true(
        (EQ_UI_DYNAMIC_RECTS[2].x + EQ_UI_DYNAMIC_RECTS[2].w) <=
            EQ_UI_PAGE_SWITCH_RECT.x &&
        (EQ_UI_EDITOR_FIELDS_RECT.x + EQ_UI_EDITOR_FIELDS_RECT.w) <=
            EQ_UI_PAGE_SWITCH_RECT.x,
        "page switch has reserved space on both pages");
#endif
    EqualizerUi_DefaultTouchTransform(&transform);
    failures += require_true(EqualizerUi_MapTouchRawToScreen(
        &transform, 0U, 0U, &x, &y) && x == 0 && y == 0, "map origin");
    failures += require_true(EqualizerUi_MapTouchRawToScreen(
        &transform, 799U, 479U, &x, &y) && x == 799 && y == 479,
        "map far corner");
    transform.flip_x = 1U;
    transform.flip_y = 1U;
    failures += require_true(EqualizerUi_MapTouchRawToScreen(
        &transform, 0U, 0U, &x, &y) && x == 799 && y == 479,
        "map flips");
    EqualizerUi_DefaultTouchTransform(&transform);
    transform.swap_xy = 1U;
    transform.raw_x_max = 479U;
    transform.raw_y_max = 799U;
    failures += require_true(EqualizerUi_MapTouchRawToScreen(
        &transform, 240U, 400U, &x, &y) && x == 400 && y == 240,
        "map swap before scale");

    EqualizerUiTouch_Init(&touch);
    x = EQ_UI_DYNAMIC_HITBOXES[0].rect.x + 2;
    y = EQ_UI_DYNAMIC_HITBOXES[0].rect.y + 2;
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_PRESET_FLAT && !rejected,
                             "first press action");
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_NONE,
                             "long press suppressed");
    (void)EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 0, x, y, &rejected);
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_PRESET_FLAT,
                             "release rearms");

    for (i = -5000; i < 5000; i++)
    {
        pixel = EqualizerUi_DbTenthsToPixel(i);
        if ((pixel < EQ_UI_ANALYZER_BAR_TOP) ||
            (pixel > EQ_UI_ANALYZER_BAR_BOTTOM))
        {
            failures += require_true(0, "analyzer clamp");
            break;
        }
    }
    failures += require_true(
        EqualizerUi_DbTenthsToPixel(5000) == EQ_UI_ANALYZER_BAR_TOP,
        "analyzer upper clamp");
    failures += require_true(
        EqualizerUi_DbTenthsToPixel(-5000) == EQ_UI_ANALYZER_BAR_BOTTOM,
        "analyzer lower clamp");
    return failures;
}

static int test_jobs_and_dynamic_semantics(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long expected;
    int failures;
    int action;

    failures = 0;
    EqualizerUiLogic_Init(&state);
    make_snapshot(&snapshot);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 1UL);
    expected = (1UL << EQ_UI_JOB_DYNAMIC_2) - 1UL;
    failures += require_true(state.dirty_mask == expected,
                             "initial logical jobs independent");
    failures += require_true(flush_jobs(&state, 1UL) == 21,
                             "one service per dynamic/analyzer field");
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 1000UL);
    failures += require_true(!EqualizerUiLogic_HasPending(&state),
                             "unchanged snapshot clean");

    snapshot.applied_preset = EQ_PRESET_BASS_BOOST;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 2000UL);
    expected = JOB_BIT(EQ_UI_JOB_PRESET_0) |
               JOB_BIT(EQ_UI_JOB_PRESET_0 + 1);
    failures += require_true(state.dirty_mask == expected,
                             "preset old and new only");
    failures += require_true(flush_jobs(&state, 2000UL) == 2,
                             "two preset fields");

    snapshot.smart_level = 1;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_DYNAMICS, 3000UL);
    snapshot.smart_level = 3;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_DYNAMICS, 3000UL);
    failures += require_true(
        EqualizerUiLogic_DynamicFieldMask(&state, 0) ==
        EQ_UI_DYNAMIC_FIELD_LEVEL, "latest level field only");
    action = EqualizerUiLogic_SelectJob(&state, 3000UL);
    complete_one(&state, action, 3000UL);
    failures += require_true(state.displayed.smart_level == 3,
                             "latest dynamic value displayed");

    EqualizerUiLogic_Init(&state);
    make_snapshot(&snapshot);
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_DYNAMICS, 4000UL);
    (void)flush_jobs(&state, 4000UL);
    snapshot.smart_enabled = 1;
    EqualizerUiLogic_Request(&state, &snapshot,
        EQ_UI_RUNTIME_CHAIN | EQ_UI_RUNTIME_DYNAMICS, 5000UL);
    failures += require_true(
        (state.dirty_mask & JOB_BIT(EQ_UI_JOB_CHAIN_0)) != 0UL &&
        (EqualizerUiLogic_DynamicFieldMask(&state, 0) &
         EQ_UI_DYNAMIC_FIELD_ENABLED) != 0U,
        "user enabled marks chain and row");
    EqualizerUiLogic_CompleteDynamicField(
        &state, EQ_UI_JOB_DYNAMIC_0, EQ_UI_DYNAMIC_FIELD_ENABLED, 5000UL);
    failures += require_true(state.displayed.smart_enabled == 1 &&
                             state.displayed.smart_level == 0,
                             "enabled remains on while processing level zero");
    snapshot.smart_level = 2;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_DYNAMICS, 5100UL);
    failures += require_true(
        EqualizerUiLogic_DynamicFieldMask(&state, 0) ==
        EQ_UI_DYNAMIC_FIELD_LEVEL && state.displayed.smart_enabled == 1,
        "processing level is independent of user enabled");
    return failures;
}

static int initialize_analyzer(EQ_UI_STATE *state,
                               EQ_UI_SNAPSHOT *snapshot)
{
    EqualizerUiLogic_Init(state);
    make_snapshot(snapshot);
    EqualizerUiLogic_Request(state, snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 0UL);
    return flush_jobs(state, 0UL);
}

static int drive_bar(EQ_UI_STATE *state, EQ_UI_SNAPSHOT *snapshot,
                     int band, unsigned long first_frame)
{
    unsigned long frame;
    int previous;
    int next;
    int steps;

    steps = 0;
    frame = first_frame;
    while ((EqualizerUiLogic_AnalyzerFieldMask(state, band) &
            EQ_UI_ANALYZER_FIELD_BAR) != 0U && steps < 64)
    {
        previous = state->displayed.band_pixel[band];
        next = EqualizerUiLogic_AnalyzerNextPixel(state, band);
        if ((next - previous > EQ_UI_ANALYZER_MAX_STRIP_HEIGHT) ||
            (previous - next > EQ_UI_ANALYZER_MAX_STRIP_HEIGHT))
        {
            return -1;
        }
        EqualizerUiLogic_CompleteAnalyzerField(
            state, EQ_UI_JOB_ANALYZER_0 + band,
            EQ_UI_ANALYZER_FIELD_BAR, frame);
        frame += EQ_UI_ANALYZER_MIN_GAP_FRAMES;
        EqualizerUiLogic_Request(state, snapshot,
                                 EQ_UI_RUNTIME_ANALYZER, frame);
        steps++;
    }
    return steps;
}

static int test_analyzer_transitions(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    int failures;
    int previous;
    int next;
    int saw_zero;
    int steps;

    failures = 0;
    failures += require_true(initialize_analyzer(&state, &snapshot) == 4,
                             "initial analyzer values only");
    failures += require_true(
        state.displayed.band_pixel[0] == EQ_UI_ANALYZER_ZERO_PIXEL,
        "analyzer starts on zero line");
    snapshot.band_pixel[3] = EQ_UI_ANALYZER_BAR_TOP;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 500UL);
    failures += require_true(
        state.requested.band_pixel[3] == EQ_UI_ANALYZER_DRAW_TOP,
        "requested extreme is normalized to drawable interior");
    snapshot.band_pixel[3] = EQ_UI_ANALYZER_ZERO_PIXEL;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 501UL);

    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL - 40;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 1000UL);
    next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
    failures += require_true(
        next == EQ_UI_ANALYZER_ZERO_PIXEL -
                EQ_UI_ANALYZER_MAX_STRIP_HEIGHT,
        "positive growth bounded");
    steps = drive_bar(&state, &snapshot, 0, 1000UL);
    failures += require_true(steps == 3 &&
        state.displayed.band_pixel[0] == snapshot.band_pixel[0],
        "positive growth reaches target");

    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL - 8;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 2000UL);
    next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
    failures += require_true(next > state.displayed.band_pixel[0] &&
        (next - state.displayed.band_pixel[0]) <=
         EQ_UI_ANALYZER_MAX_STRIP_HEIGHT,
        "positive shrink clears toward zero");
    failures += require_true(drive_bar(&state, &snapshot, 0, 2000UL) == 2,
                             "positive shrink staged");

    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL + 40;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 3000UL);
    saw_zero = 0;
    for (steps = 0; steps < 16; steps++)
    {
        previous = state.displayed.band_pixel[0];
        next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
        if (!saw_zero && (next > EQ_UI_ANALYZER_ZERO_PIXEL))
        {
            failures += require_true(0, "positive to negative crossed zero");
            break;
        }
        EqualizerUiLogic_CompleteAnalyzerField(
            &state, EQ_UI_JOB_ANALYZER_0,
            EQ_UI_ANALYZER_FIELD_BAR,
            3000UL + (unsigned long)steps * 8UL);
        if (state.displayed.band_pixel[0] == EQ_UI_ANALYZER_ZERO_PIXEL)
            saw_zero = 1;
        EqualizerUiLogic_Request(
            &state, &snapshot, EQ_UI_RUNTIME_ANALYZER,
            3008UL + (unsigned long)steps * 8UL);
        if ((EqualizerUiLogic_AnalyzerFieldMask(&state, 0) &
             EQ_UI_ANALYZER_FIELD_BAR) == 0U)
            break;
        failures += require_true(previous != state.displayed.band_pixel[0],
                                 "cross-zero stage makes progress");
    }
    failures += require_true(saw_zero &&
        state.displayed.band_pixel[0] == snapshot.band_pixel[0],
        "positive to negative reaches latest target via zero");

    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL - 60;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 4000UL);
    EqualizerUiLogic_CompleteAnalyzerField(
        &state, EQ_UI_JOB_ANALYZER_0, EQ_UI_ANALYZER_FIELD_BAR, 4000UL);
    previous = state.displayed.band_pixel[0];
    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL + 56;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, 4001UL);
    next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
    failures += require_true(next > previous,
        "latest target reverses old positive-side request immediately");
    failures += require_true(drive_bar(&state, &snapshot, 0, 4008UL) > 0 &&
        state.displayed.band_pixel[0] == snapshot.band_pixel[0],
        "latest-wins leaves no queued old target");
    return failures;
}

static int test_analyzer_value_throttle(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long last;
    int failures;

    failures = 0;
    (void)initialize_analyzer(&state, &snapshot);
    last = state.band_last_value_frame[0];
    snapshot.band_value_db[0] = 1;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, last + 1UL);
    failures += require_true(!EqualizerUiLogic_HasPending(&state),
                             "one dB value jitter delayed");
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ANALYZER,
        last + EQ_UI_ANALYZER_VALUE_MAX_AGE_FRAMES);
    failures += require_true(
        EqualizerUiLogic_AnalyzerFieldMask(&state, 0) ==
        EQ_UI_ANALYZER_FIELD_VALUE, "one dB value expires at 50 frames");
    EqualizerUiLogic_CompleteAnalyzerField(
        &state, EQ_UI_JOB_ANALYZER_0, EQ_UI_ANALYZER_FIELD_VALUE,
        last + EQ_UI_ANALYZER_VALUE_MAX_AGE_FRAMES);
    snapshot.band_value_db[0] = 3;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ANALYZER,
        last + EQ_UI_ANALYZER_VALUE_MAX_AGE_FRAMES + 1UL);
    failures += require_true(
        EqualizerUiLogic_AnalyzerFieldMask(&state, 0) ==
        EQ_UI_ANALYZER_FIELD_VALUE, "two dB value change immediate");
    EqualizerUiLogic_CompleteAnalyzerField(
        &state, EQ_UI_JOB_ANALYZER_0, EQ_UI_ANALYZER_FIELD_VALUE,
        last + EQ_UI_ANALYZER_VALUE_MAX_AGE_FRAMES + 1UL);
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ANALYZER,
        last + 200UL);
    failures += require_true(!EqualizerUiLogic_HasPending(&state),
                             "unchanged value is not periodically redrawn");
    snapshot.analyzer_warm = 0;
    EqualizerUiLogic_Request(&state, &snapshot,
                             EQ_UI_RUNTIME_ANALYZER, last + 201UL);
    failures += require_true(
        (EqualizerUiLogic_AnalyzerFieldMask(&state, 0) &
         EQ_UI_ANALYZER_FIELD_VALUE) != 0U &&
        EqualizerUiLogic_AnalyzerNextField(&state, 0) ==
         EQ_UI_ANALYZER_FIELD_VALUE,
        "warm state text has priority");
    return failures;
}

static int test_service_gaps(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long frame;
    int failures;
    int job;
    int count;

    failures = 0;
    make_snapshot(&snapshot);

    EqualizerUiLogic_Init(&state);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_PRESET, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_one(&state, job, 0UL);
    failures += require_true(
        !EqualizerUiLogic_HasEligibleJob(&state, 1UL) &&
        EqualizerUiLogic_SelectJob(&state, 1UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 2UL) != EQ_UI_JOB_NONE,
        "preset gap is two frames");

    EqualizerUiLogic_Init(&state);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_DYNAMICS, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_one(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 3UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 7UL) != EQ_UI_JOB_NONE,
        "dynamic gap and steady cap enforced");

    EqualizerUiLogic_Init(&state);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_CHAIN, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_one(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 7UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 8UL) != EQ_UI_JOB_NONE,
        "chain gap is eight frames");

    EqualizerUiLogic_Init(&state);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ANALYZER, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_one(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 0UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 7UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 8UL) != EQ_UI_JOB_NONE,
        "analyzer and same-frame gaps enforced");

    EqualizerUiLogic_Init(&state);
    count = 0;
    for (frame = 0UL; frame < 4883UL; frame++)
    {
        snapshot.smart_level = (int)(frame & 3UL);
        EqualizerUiLogic_Request(&state, &snapshot,
                                 EQ_UI_RUNTIME_DYNAMICS, frame);
        job = EqualizerUiLogic_SelectJob(&state, frame);
        if (job != EQ_UI_JOB_NONE)
        {
            complete_one(&state, job, frame);
            count++;
        }
    }
    failures += require_true(count <= 800,
                             "100 second steady rate at most eight jobs/s");
    return failures;
}

#if EQ_ENABLE_TEN_BAND_EDITOR != 0
static int test_editor_state_model(void)
{
    EQ_UI_EDITOR_STATE editor;
    EQ_UI_GAIN_HALF_DB applied[EQ_NUM_BANDS];
    float gains_db[EQ_NUM_BANDS];
    int failures;
    int band;

    failures = 0;
    memset(applied, 0, sizeof(applied));
    EqualizerUiEditor_Init(&editor);
    failures += require_true(sizeof(editor) <= 512U,
                              "editor state budget");
    failures += require_true(editor.selected_band == 0 &&
        editor.applied_preset == EQ_PRESET_FLAT &&
        editor.apply_status == EQ_UI_APPLY_APPLIED,
        "editor defaults");
    failures += require_true(EqualizerUiEditor_SelectBand(&editor, 2),
                              "select 125 Hz");
    for (band = 0; band < 4; band++)
    {
        failures += require_true(
            EqualizerUiEditor_StepSelected(&editor, 1),
            "half dB draft step");
    }
    failures += require_true(editor.draft_gain_half_db[2] == 4 &&
        editor.draft_dirty != 0U && editor.draft_version == 4UL,
        "draft is local half dB state");
    failures += require_true(
        EqualizerUiEditor_HasSubmittableDraft(&editor),
        "draft can submit once");
    EqualizerUiEditor_CopyDraftDb(&editor, gains_db);
    failures += require_true(gains_db[2] == 2.0f,
                              "transient float conversion");
    EqualizerUiEditor_MarkSubmitted(&editor, 1U);
    failures += require_true(!EqualizerUiEditor_HasSubmittableDraft(&editor) &&
        editor.submitted_gain_half_db[2] == 4 &&
        editor.apply_status == EQ_UI_APPLY_QUEUED,
        "duplicate draft suppressed");
    applied[2] = 4;
    EqualizerUiEditor_ObserveApplied(
        &editor, applied, EQ_PRESET_CUSTOM, 1U);
    failures += require_true(editor.applied_preset == EQ_PRESET_CUSTOM &&
        editor.applied_gain_half_db[2] == 4 &&
        editor.draft_dirty == 0U &&
        editor.apply_status == EQ_UI_APPLY_APPLIED,
        "custom only becomes applied on applied sequence");
    for (band = 0; band < 100; band++)
    {
        (void)EqualizerUiEditor_StepSelected(&editor, 1);
    }
    failures += require_true(editor.draft_gain_half_db[2] ==
        EQ_UI_GAIN_HALF_DB_MAX, "upper gain clamp");
    for (band = 0; band < 100; band++)
    {
        (void)EqualizerUiEditor_StepSelected(&editor, -1);
    }
    failures += require_true(editor.draft_gain_half_db[2] ==
        EQ_UI_GAIN_HALF_DB_MIN, "lower gain clamp");
    memset(applied, 0, sizeof(applied));
    applied[0] = 6;
    EqualizerUiEditor_ObserveApplied(
        &editor, applied, EQ_PRESET_BASS_BOOST, 2U);
    failures += require_true(editor.applied_preset == EQ_PRESET_BASS_BOOST &&
        editor.draft_gain_half_db[0] == 6 &&
        editor.submitted_gain_half_db[0] == 6 &&
        editor.draft_dirty == 0U,
        "fixed preset discards unsubmitted draft");
    failures += require_true(EqualizerUi_GainDbToHalf(12.5f) == 24 &&
        EqualizerUi_GainDbToHalf(-19.0f) == -36 &&
        EqualizerUi_GainDbToHalf(2.24f) == 4,
        "gain conversion clamps and rounds");
    return failures;
}

static int test_editor_pages_jobs_and_touch(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    EQ_UI_TOUCH_STATE touch;
    int failures;
    int job;
    int x;
    int y;
    int action;
    int rejected;
    int before;
    int after;

    failures = 0;
    failures += require_true(EQ_UI_JOB_COUNT == 27,
                              "editor job count");
    EqualizerUiLogic_Init(&state);
    make_snapshot(&snapshot);
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 0UL);
    failures += require_true(flush_jobs(&state, 0UL) == 21,
                              "dynamic page initial jobs");

    snapshot.page = EQ_UI_PAGE_EQ_EDITOR;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 1000UL);
    failures += require_true(EqualizerUiLogic_IsPageBuilding(&state) &&
        EqualizerUiLogic_GetDisplayedPage(&state) ==
            EQ_UI_PAGE_DYNAMIC_STATUS &&
        state.dirty_mask == JOB_BIT(EQ_UI_JOB_PAGE_TILE) &&
        EqualizerUiLogic_GetPageTileCount(&state) ==
            EQ_UI_PAGE_TILE_EDITOR_COUNT,
        "page build starts as one tiled job");
    job = EqualizerUiLogic_SelectJob(&state, 1000UL);
    complete_one(&state, job, 1000UL);
    snapshot.page = EQ_UI_PAGE_DYNAMIC_STATUS;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 1001UL);
    failures += require_true(EqualizerUiLogic_GetPageTileIndex(&state) == 0U &&
        EqualizerUiLogic_GetPageTileCount(&state) == 0U &&
        state.page_target == EQ_UI_PAGE_DYNAMIC_STATUS &&
        !EqualizerUiLogic_IsPageBuilding(&state),
        "latest request cancels a hidden-page build");
    failures += require_true(flush_jobs(&state, 1002UL) == 0,
        "cancelling hidden build never redraws the visible page");

    snapshot.page = EQ_UI_PAGE_EQ_EDITOR;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 2000UL);
    before = flush_jobs(&state, 2000UL);
    failures += require_true(before == (int)EQ_UI_PAGE_TILE_EDITOR_COUNT &&
        EqualizerUiLogic_GetDisplayedPage(&state) == EQ_UI_PAGE_EQ_EDITOR &&
        !EqualizerUiLogic_IsPageBuilding(&state) &&
        !EqualizerUiLogic_HasPending(&state),
        "displayed page changes after final tile only");

    snapshot.applied_preset = EQ_PRESET_CUSTOM;
    snapshot.applied_gain_half_db[2] = 24;
    snapshot.editor_selected_band = 2;
    snapshot.editor_draft_version++;
    snapshot.draft_gain_half_db[2] = 24;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 3000UL);
    failures += require_true(
        (state.dirty_mask & JOB_BIT(EQ_UI_JOB_EDITOR_BAND_0 + 2)) != 0UL &&
        (state.dirty_mask & JOB_BIT(EQ_UI_JOB_EDITOR_FIELDS)) != 0UL &&
        (state.dirty_mask & (0x7FFFUL)) ==
            (JOB_BIT(EQ_UI_JOB_PRESET_0)),
        "custom editor dirties old preset, one band, shared fields");
    before = state.editor_displayed_pixel[2];
    job = EQ_UI_JOB_EDITOR_BAND_0 + 2;
    EqualizerUiLogic_CompleteEditorBand(&state, job, 3000UL);
    after = state.editor_displayed_pixel[2];
    failures += require_true((before - after) > 0 &&
        (before - after) <= EQ_UI_EDITOR_MAX_STRIP_HEIGHT,
        "editor applied bar uses bounded differential strip");
    failures += require_true(flush_jobs(&state, 3002UL) > 0 &&
        !EqualizerUiLogic_HasPending(&state),
        "editor jobs converge");
    snapshot.smart_level = 3;
    EqualizerUiLogic_Request(&state, &snapshot, EQ_UI_RUNTIME_ALL, 4000UL);
    failures += require_true(!EqualizerUiLogic_HasPending(&state),
                              "hidden dynamic page creates no content job");

    failures += require_true(
        EqualizerUi_HitTest(EQ_UI_PAGE_DYNAMIC_STATUS,
            EQ_UI_DYNAMIC_TOGGLE_RECTS[0].x + 1,
            EQ_UI_DYNAMIC_TOGGLE_RECTS[0].y + 1) ==
            EQ_UI_ACTION_SMART_TOGGLE,
        "dynamic page hitbox");
    failures += require_true(
        EqualizerUi_HitTest(EQ_UI_PAGE_EQ_EDITOR,
            EQ_UI_EDITOR_BAND_RECTS[2].x + 1,
            EQ_UI_EDITOR_BAND_RECTS[2].y + 1) ==
            EQ_UI_ACTION_EDITOR_BAND_2,
        "editor page hitbox");
    EqualizerUiTouch_Init(&touch);
    x = EQ_UI_EDITOR_BAND_RECTS[2].x + 1;
    y = EQ_UI_EDITOR_BAND_RECTS[2].y + 1;
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_EQ_EDITOR, 1, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_NONE && rejected,
                              "content action rejected while page builds");
    (void)EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_EQ_EDITOR, 1, 0, x, y, &rejected);
    x = EQ_UI_PAGE_SWITCH_RECT.x + 1;
    y = EQ_UI_PAGE_SWITCH_RECT.y + 1;
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_EQ_EDITOR, 1, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_PAGE_SWITCH && !rejected,
                              "page switch remains latest-wins while building");
    return failures;
}
#endif

int main(void)
{
    int failures;

    failures = 0;
    failures += test_layout_and_touch();
    failures += test_jobs_and_dynamic_semantics();
    failures += test_analyzer_transitions();
    failures += test_analyzer_value_throttle();
    failures += test_service_gaps();
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += test_editor_state_model();
    failures += test_editor_pages_jobs_and_touch();
#endif
    printf("equalizer_ui_logic failures=%d\n", failures);
    return (failures == 0) ? 0 : 1;
}
