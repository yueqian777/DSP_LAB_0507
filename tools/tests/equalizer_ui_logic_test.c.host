#include "user_equalizer_ui_logic.h"

#include <stdio.h>
#include <string.h>

#define JOB_BIT(job_) (1UL << ((job_) - 1))

static int require_true(int condition, const char *message)
{
    if (!condition)
    {
        printf("equalizer_ui_logic FAIL: %s\n", message);
        return 1;
    }
    return 0;
}

static void make_snapshot(EQ_UI_SNAPSHOT *snapshot)
{
    int band;

    memset(snapshot, 0, sizeof(*snapshot));
    snapshot->applied_preset = EQ_PRESET_FLAT;
    snapshot->smart_strength = 2;
    snapshot->clarity_strength = 2;
    snapshot->guard_strength = 2;
    snapshot->analyzer_valid = 1;
    snapshot->analyzer_warm = 1;
    for (band = 0; band < EQ_UI_ANALYZER_COUNT; band++)
    {
        snapshot->band_pixel[band] = EQ_UI_ANALYZER_ZERO_PIXEL;
    }
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    snapshot->page = EQ_UI_PAGE_DYNAMIC_STATUS;
    snapshot->editor_selected_band = 0;
    snapshot->editor_apply_status = EQ_UI_APPLY_APPLIED;
    snapshot->editor_submitted_valid = 1U;
#endif
}

static void initialize_rendered(EQ_UI_STATE *state,
                                EQ_UI_SNAPSHOT *snapshot)
{
    EqualizerUiLogic_Init(state);
    make_snapshot(snapshot);
    EqualizerUiLogic_Request(state, snapshot, EQ_UI_RUNTIME_ALL, 0UL);
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    EqualizerUiLogic_MarkStartupRendered(state);
#else
    while (EqualizerUiLogic_HasPending(state))
    {
        int job;

        job = EqualizerUiLogic_SelectJob(state, state->last_service_frame + 8UL);
        if (job != EQ_UI_JOB_NONE)
        {
            EqualizerUiLogic_CompleteJob(
                state, job, state->last_service_frame + 8UL);
        }
    }
#endif
}

#if EQ_ENABLE_TEN_BAND_EDITOR != 0
static unsigned int selected_fields(const EQ_UI_STATE *state, int job)
{
    unsigned int fields;

    if ((job >= EQ_UI_JOB_DYNAMIC_0) &&
        (job <= EQ_UI_JOB_DYNAMIC_2))
    {
        fields = EqualizerUiLogic_DynamicFieldMask(
            state, job - EQ_UI_JOB_DYNAMIC_0);
        if ((fields & EQ_UI_DYNAMIC_FIELD_ENABLED) != 0U)
            return EQ_UI_DYNAMIC_FIELD_ENABLED;
        if ((fields & EQ_UI_DYNAMIC_FIELD_STRENGTH) != 0U)
            return EQ_UI_DYNAMIC_FIELD_STRENGTH;
        return fields & EQ_UI_DYNAMIC_FIELD_ACTIVE;
    }
    if ((job >= EQ_UI_JOB_ANALYZER_0) &&
        (job <= EQ_UI_JOB_ANALYZER_3))
    {
        return EqualizerUiLogic_AnalyzerNextField(
            state, job - EQ_UI_JOB_ANALYZER_0);
    }
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    if (job == EQ_UI_JOB_EDITOR_FIELDS)
    {
        return EqualizerUiLogic_EditorNextField(state);
    }
#endif
    return 0U;
}
#endif

static void complete_job(EQ_UI_STATE *state, int job,
                         unsigned long process_frame)
{
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    if (job == EQ_UI_JOB_PAGE_SYNC)
    {
        EqualizerUiLogic_CompletePageSync(
            state,
            selected_fields(state,
                EqualizerUiLogic_GetPageSyncJob(state)),
            process_frame);
        return;
    }
    if (job == EQ_UI_JOB_PAGE_SWAP)
    {
        EqualizerUiLogic_CompletePageSwap(state, process_frame);
        return;
    }
#endif
    EqualizerUiLogic_CompleteJob(state, job, process_frame);
}

static int flush_jobs(EQ_UI_STATE *state, unsigned long start_frame,
                      int maximum)
{
    unsigned long frame;
    int count;
    int job;

    frame = start_frame;
    count = 0;
    while (EqualizerUiLogic_HasPending(state) && (count < maximum))
    {
        job = EqualizerUiLogic_SelectJob(state, frame);
        if (job != EQ_UI_JOB_NONE)
        {
            complete_job(state, job, frame);
            count++;
        }
        frame += 8UL;
    }
    return count;
}

static int test_layout_and_touch(void)
{
    EQ_UI_TOUCH_TRANSFORM transform;
    EQ_UI_TOUCH_STATE touch;
    int failures;
    int screen_x;
    int screen_y;
    int action;
    int rejected;
    int x;
    int y;

    failures = 0;
    failures += require_true(EqualizerUi_ValidateLayout(),
                             "layout validates");
    failures += require_true(EQ_UI_DYNAMIC_HITBOX_COUNT == 12,
                             "dynamic hitbox count is 12");
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += require_true(EQ_UI_EDITOR_HITBOX_COUNT == 15,
                             "editor hitbox count is 15");
    failures += require_true(EQ_UI_JOB_PAGE_SYNC == 24 &&
                             EQ_UI_JOB_PAGE_SWAP == 25 &&
                             EQ_UI_JOB_COUNT == 25,
                             "page jobs and total job count");
    failures += require_true(
        EqualizerUi_HitTest(EQ_UI_PAGE_EQ_EDITOR, 30, 40) ==
            EQ_UI_ACTION_NONE,
        "editor has no duplicate preset row hitbox");
    failures += require_true(
        EqualizerUi_HitTest(
            EQ_UI_PAGE_EQ_EDITOR,
            EQ_UI_EDITOR_BAND_RECTS[2].x + 1,
            EQ_UI_EDITOR_BAND_RECTS[2].y + 1) ==
            EQ_UI_ACTION_EDITOR_BAND_2,
        "editor band hitbox");
#endif
    failures += require_true(
        EqualizerUi_HitTest(
            EQ_UI_PAGE_DYNAMIC_STATUS,
            EQ_UI_DYNAMIC_STATUS_RECTS[0].x + 1,
            EQ_UI_DYNAMIC_STATUS_RECTS[0].y + 1) ==
            EQ_UI_ACTION_NONE,
        "active indicator is read-only");

    EqualizerUi_DefaultTouchTransform(&transform);
    failures += require_true(
        EqualizerUi_MapTouchRawToScreen(
            &transform, 799U, 479U, &screen_x, &screen_y) &&
        screen_x == 799 && screen_y == 479,
        "identity touch transform");
    transform.flip_x = 1U;
    transform.flip_y = 1U;
    failures += require_true(
        EqualizerUi_MapTouchRawToScreen(
            &transform, 799U, 479U, &screen_x, &screen_y) &&
        screen_x == 0 && screen_y == 0,
        "touch axis flips");

    EqualizerUiTouch_Init(&touch);
    x = EQ_UI_PAGE_SWITCH_RECT.x + 1;
    y = EQ_UI_PAGE_SWITCH_RECT.y + 1;
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_PAGE_SWITCH && !rejected,
                             "page switch accepted while idle");
    (void)EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 0, 0, x, y, &rejected);
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 1, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_NONE && rejected,
                             "page switch rejected during page sync");
    (void)EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_DYNAMIC_STATUS, 1, 0, x, y, &rejected);
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    x = EQ_UI_EDITOR_BAND_RECTS[4].x + 1;
    y = EQ_UI_EDITOR_BAND_RECTS[4].y + 1;
    action = EqualizerUiTouch_Process(
        &touch, EQ_UI_PAGE_EQ_EDITOR, 1, 1, x, y, &rejected);
    failures += require_true(action == EQ_UI_ACTION_NONE && rejected,
                             "editor action rejected during page swap");
#endif
    return failures;
}

static int test_dynamic_active_semantics(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned int fields;
    int failures;

    failures = 0;
    initialize_rendered(&state, &snapshot);
    snapshot.smart_enabled = 1;
    snapshot.smart_strength = 3;
    snapshot.smart_active = 1;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 100UL);
    fields = EqualizerUiLogic_DynamicFieldMask(&state, 0);
    failures += require_true(fields == EQ_UI_DYNAMIC_FIELD_ALL,
                             "dynamic row exposes enabled strength active");
    EqualizerUiLogic_CompleteDynamicField(
        &state, EQ_UI_JOB_DYNAMIC_0,
        EQ_UI_DYNAMIC_FIELD_ENABLED, 100UL);
    failures += require_true(state.displayed.smart_enabled == 1 &&
        state.displayed.smart_strength == 2 &&
        state.displayed.smart_active == 0,
        "dynamic fields complete independently");
    snapshot.smart_active = 0;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 101UL);
    snapshot.smart_active = 7;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 102UL);
    failures += require_true(
        (EqualizerUiLogic_DynamicFieldMask(&state, 0) &
         EQ_UI_DYNAMIC_FIELD_ACTIVE) != 0U &&
        state.requested.smart_active == 1,
        "dynamic active request is normalized and latest-wins");
    failures += require_true(flush_jobs(&state, 108UL, 32) > 0 &&
        state.displayed.smart_enabled == 1 &&
        state.displayed.smart_strength == 3 &&
        state.displayed.smart_active == 1 &&
        !EqualizerUiLogic_HasPending(&state),
        "dynamic active row converges");
    return failures;
}

static int test_analyzer_bar_only(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long last_frame;
    int failures;
    int current;
    int next;
    int steps;

    failures = 0;
    initialize_rendered(&state, &snapshot);
    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL - 40;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 1000UL);
    failures += require_true(
        EqualizerUiLogic_AnalyzerFieldMask(&state, 0) ==
            EQ_UI_ANALYZER_FIELD_BAR &&
        EqualizerUiLogic_AnalyzerNextField(&state, 0) ==
            EQ_UI_ANALYZER_FIELD_BAR,
        "analyzer has one bar-only field");
    current = state.displayed.band_pixel[0];
    next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
    failures += require_true(current - next > 0 &&
        current - next <= EQ_UI_ANALYZER_MAX_STRIP_HEIGHT,
        "analyzer growth is bounded");
    steps = 0;
    while ((EqualizerUiLogic_AnalyzerFieldMask(&state, 0) &
            EQ_UI_ANALYZER_FIELD_BAR) != 0U && steps < 16)
    {
        EqualizerUiLogic_CompleteAnalyzerField(
            &state, EQ_UI_JOB_ANALYZER_0,
            EQ_UI_ANALYZER_FIELD_BAR,
            1000UL + (unsigned long)steps * 8UL);
        steps++;
    }
    failures += require_true(steps == 3 &&
        state.displayed.band_pixel[0] == snapshot.band_pixel[0],
        "analyzer reaches target through bounded strips");

    last_frame = state.band_last_display_frame[0];
    snapshot.band_pixel[0]++;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, last_frame + 1UL);
    failures += require_true(
        EqualizerUiLogic_AnalyzerFieldMask(&state, 0) == 0U,
        "one-pixel analyzer jitter is delayed");
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL,
        last_frame + EQ_UI_ANALYZER_MAX_AGE_FRAMES);
    failures += require_true(
        EqualizerUiLogic_AnalyzerFieldMask(&state, 0) ==
            EQ_UI_ANALYZER_FIELD_BAR,
        "one-pixel analyzer change expires at max age");

    snapshot.band_pixel[0] = EQ_UI_ANALYZER_ZERO_PIXEL + 40;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 2000UL);
    while (state.displayed.band_pixel[0] != EQ_UI_ANALYZER_ZERO_PIXEL)
    {
        next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
        failures += require_true(next <= EQ_UI_ANALYZER_ZERO_PIXEL,
                                 "cross-zero clears old direction first");
        EqualizerUiLogic_CompleteAnalyzerField(
            &state, EQ_UI_JOB_ANALYZER_0,
            EQ_UI_ANALYZER_FIELD_BAR, 2000UL);
    }
    next = EqualizerUiLogic_AnalyzerNextPixel(&state, 0);
    failures += require_true(next > EQ_UI_ANALYZER_ZERO_PIXEL,
                             "cross-zero fills new direction after zero");
    return failures;
}

static int test_service_gaps(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long frame;
    int failures;
    int job;
    int count;

    failures = 0;
    initialize_rendered(&state, &snapshot);
    snapshot.applied_preset = EQ_PRESET_BASS_BOOST;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_job(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 1UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 2UL) != EQ_UI_JOB_NONE,
        "preset gap is two frames");

    initialize_rendered(&state, &snapshot);
    snapshot.smart_enabled = 1;
    snapshot.clarity_enabled = 1;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_job(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 6UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 7UL) != EQ_UI_JOB_NONE,
        "dynamic global gap is seven frames");

    initialize_rendered(&state, &snapshot);
    snapshot.band_pixel[0] -= 20;
    snapshot.band_pixel[1] -= 20;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 0UL);
    job = EqualizerUiLogic_SelectJob(&state, 0UL);
    complete_job(&state, job, 0UL);
    failures += require_true(
        EqualizerUiLogic_SelectJob(&state, 7UL) == EQ_UI_JOB_NONE &&
        EqualizerUiLogic_SelectJob(&state, 8UL) != EQ_UI_JOB_NONE,
        "analyzer gap is eight frames");

    initialize_rendered(&state, &snapshot);
    count = 0;
    for (frame = 0UL; frame < 4883UL; frame++)
    {
        snapshot.smart_active = (int)(frame & 1UL);
        EqualizerUiLogic_Request(
            &state, &snapshot, EQ_UI_RUNTIME_ALL, frame);
        job = EqualizerUiLogic_SelectJob(&state, frame);
        if (job != EQ_UI_JOB_NONE)
        {
            complete_job(&state, job, frame);
            count++;
        }
    }
    failures += require_true(count <= 800,
                             "steady UI rate stays bounded");
    return failures;
}

#if EQ_ENABLE_TEN_BAND_EDITOR != 0
static int test_editor_state_model(void)
{
    EQ_UI_EDITOR_STATE editor;
    EQ_UI_GAIN_HALF_DB applied[EQ_NUM_BANDS];
    float gains_db[EQ_NUM_BANDS];
    int failures;
    int band;

    failures = 0;
    memset(applied, 0, sizeof(applied));
    EqualizerUiEditor_Init(&editor);
    failures += require_true(sizeof(editor) <= 512U,
                             "editor state budget");
    failures += require_true(editor.selected_band == 0 &&
        editor.applied_preset == EQ_PRESET_FLAT &&
        editor.apply_status == EQ_UI_APPLY_APPLIED,
        "editor defaults");
    failures += require_true(EqualizerUiEditor_SelectBand(&editor, 2),
                             "select 125 Hz");
    for (band = 0; band < 4; band++)
    {
        failures += require_true(
            EqualizerUiEditor_StepSelected(&editor, 1),
            "half dB draft step");
    }
    failures += require_true(editor.draft_gain_half_db[2] == 4 &&
        editor.draft_dirty != 0U && editor.draft_version == 4UL,
        "draft is local half dB state");
    EqualizerUiEditor_CopyDraftDb(&editor, gains_db);
    failures += require_true(gains_db[2] == 2.0f,
                             "transient float conversion");
    EqualizerUiEditor_MarkSubmitted(&editor, 1U);
    failures += require_true(!EqualizerUiEditor_HasSubmittableDraft(&editor) &&
        editor.submitted_gain_half_db[2] == 4 &&
        editor.apply_status == EQ_UI_APPLY_QUEUED,
        "duplicate draft suppressed");
    applied[2] = 4;
    EqualizerUiEditor_ObserveApplied(
        &editor, applied, EQ_PRESET_CUSTOM, 1U);
    failures += require_true(editor.applied_preset == EQ_PRESET_CUSTOM &&
        editor.applied_gain_half_db[2] == 4 &&
        editor.draft_dirty == 0U &&
        editor.apply_status == EQ_UI_APPLY_APPLIED,
        "custom becomes applied on applied sequence");
    for (band = 0; band < 100; band++)
        (void)EqualizerUiEditor_StepSelected(&editor, 1);
    failures += require_true(editor.draft_gain_half_db[2] ==
        EQ_UI_GAIN_HALF_DB_MAX, "upper gain clamp");
    for (band = 0; band < 100; band++)
        (void)EqualizerUiEditor_StepSelected(&editor, -1);
    failures += require_true(editor.draft_gain_half_db[2] ==
        EQ_UI_GAIN_HALF_DB_MIN, "lower gain clamp");
    return failures;
}

static int test_permanent_pages_latest_wins(void)
{
    EQ_UI_STATE state;
    EQ_UI_SNAPSHOT snapshot;
    unsigned long editor_version;
    int failures;
    int job;
    int sync_count;
    int saw_last_sync_boundary;

    failures = 0;
    initialize_rendered(&state, &snapshot);
    failures += require_true(
        EqualizerUiLogic_GetPageDirtyMask(
            &state, EQ_UI_PAGE_DYNAMIC_STATUS) == 0UL &&
        EqualizerUiLogic_GetPageDirtyMask(
            &state, EQ_UI_PAGE_EQ_EDITOR) == 0UL &&
        state.page_rendered_version[0] == state.page_requested_version[0] &&
        state.page_rendered_version[1] == state.page_requested_version[1],
        "both permanent pages start rendered and clean");

    snapshot.editor_selected_band = 2;
    snapshot.applied_gain_half_db[2] = 8;
    snapshot.draft_gain_half_db[2] = 8;
    snapshot.editor_draft_version = 1UL;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 100UL);
    snapshot.applied_gain_half_db[2] = -6;
    snapshot.draft_gain_half_db[2] = -6;
    snapshot.editor_draft_version = 2UL;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 101UL);
    editor_version = state.page_requested_version[EQ_UI_PAGE_EQ_EDITOR];
    failures += require_true(
        EqualizerUiLogic_GetPageDirtyMask(
            &state, EQ_UI_PAGE_EQ_EDITOR) != 0UL &&
        EqualizerUiLogic_GetPageDirtyMask(
            &state, EQ_UI_PAGE_DYNAMIC_STATUS) == 0UL &&
        !EqualizerUiLogic_HasPending(&state),
        "hidden editor accumulates latest state without drawing");

    snapshot.page = EQ_UI_PAGE_EQ_EDITOR;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 120UL);
    failures += require_true(
        EqualizerUiLogic_GetPagePhase(&state) == EQ_UI_PAGE_PHASE_SYNC &&
        EqualizerUiLogic_GetDisplayedPage(&state) ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "page change enters sync while old page remains visible");
    sync_count = 0;
    saw_last_sync_boundary = 0;
    while (EqualizerUiLogic_GetPagePhase(&state) == EQ_UI_PAGE_PHASE_SYNC &&
           sync_count < 64)
    {
        job = EqualizerUiLogic_SelectJob(
            &state, 128UL + (unsigned long)sync_count * 8UL);
        if (job == EQ_UI_JOB_PAGE_SYNC)
        {
            complete_job(&state, job,
                         128UL + (unsigned long)sync_count * 8UL);
            sync_count++;
            if (EqualizerUiLogic_GetPageDirtyMask(
                    &state, EQ_UI_PAGE_EQ_EDITOR) == 0UL)
            {
                saw_last_sync_boundary = 1;
                break;
            }
        }
        else
        {
            break;
        }
    }
    failures += require_true(saw_last_sync_boundary && sync_count > 0 &&
        EqualizerUiLogic_GetPagePhase(&state) == EQ_UI_PAGE_PHASE_SYNC &&
        EqualizerUiLogic_GetDisplayedPage(&state) ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "final sync does not install page in the same service call");
    job = EqualizerUiLogic_SelectJob(&state, 1000UL);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EqualizerUiLogic_GetPagePhase(&state) == EQ_UI_PAGE_PHASE_SWAP &&
        EqualizerUiLogic_GetDisplayedPage(&state) ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "next service starts PAGE_SWAP");
    complete_job(&state, job, 1000UL);
    failures += require_true(
        EqualizerUiLogic_GetDisplayedPage(&state) == EQ_UI_PAGE_EQ_EDITOR &&
        state.editor_displayed_applied_gain[2] == -6 &&
        state.displayed.editor_selected_band == 2 &&
        state.page_rendered_version[EQ_UI_PAGE_EQ_EDITOR] ==
            state.page_requested_version[EQ_UI_PAGE_EQ_EDITOR] &&
        state.page_requested_version[EQ_UI_PAGE_EQ_EDITOR] > editor_version,
        "editor swap exposes only the latest hidden snapshot");

    snapshot.smart_enabled = 1;
    snapshot.smart_strength = 1;
    snapshot.smart_active = 0;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 1100UL);
    snapshot.smart_strength = 3;
    snapshot.smart_active = 1;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 1101UL);
    failures += require_true(
        EqualizerUiLogic_GetPageDirtyMask(
            &state, EQ_UI_PAGE_DYNAMIC_STATUS) != 0UL &&
        !EqualizerUiLogic_HasPending(&state),
        "hidden dynamic page is not serviced while editor is visible");
    snapshot.page = EQ_UI_PAGE_DYNAMIC_STATUS;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 1110UL);
    failures += require_true(flush_jobs(&state, 1120UL, 64) > 1 &&
        EqualizerUiLogic_GetDisplayedPage(&state) ==
            EQ_UI_PAGE_DYNAMIC_STATUS &&
        state.displayed.smart_enabled == 1 &&
        state.displayed.smart_strength == 3 &&
        state.displayed.smart_active == 1,
        "dynamic page sync is latest-wins");

    snapshot.page = EQ_UI_PAGE_EQ_EDITOR;
    EqualizerUiLogic_Request(
        &state, &snapshot, EQ_UI_RUNTIME_ALL, 2000UL);
    job = EqualizerUiLogic_SelectJob(&state, 2000UL);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EqualizerUiLogic_GetPageSyncJob(&state) == EQ_UI_JOB_NONE,
        "clean permanent page switch needs no PAGE_SYNC data job");
    return failures;
}
#endif

int main(void)
{
    int failures;

    failures = 0;
    failures += test_layout_and_touch();
    failures += test_dynamic_active_semantics();
    failures += test_analyzer_bar_only();
    failures += test_service_gaps();
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += test_editor_state_model();
    failures += test_permanent_pages_latest_wins();
#endif
    printf("equalizer_ui_logic failures=%d\n", failures);
    return (failures == 0) ? 0 : 1;
}
