#include "user_equalizer_display.h"

#include <stdio.h>
#include <string.h>

#if EQ_ENABLE_TEN_BAND_EDITOR != 0
#define EQ_TEST_EDITOR_HITBOX_COUNT EQ_UI_EDITOR_HITBOX_COUNT
#else
#define EQ_TEST_EDITOR_HITBOX_COUNT 0U
#endif

static int flush_jobs(unsigned long start_frame, int maximum);

static int require_true(int condition, const char *message)
{
    if (!condition)
    {
        printf("equalizer_display FAIL: %s\n", message);
        return 1;
    }
    return 0;
}

static void make_snapshot(EQ_UI_SNAPSHOT *snapshot)
{
    int band;

    memset(snapshot, 0, sizeof(*snapshot));
    snapshot->applied_preset = EQ_PRESET_FLAT;
    snapshot->smart_strength = 2;
    snapshot->clarity_strength = 2;
    snapshot->guard_strength = 2;
    snapshot->analyzer_valid = 1;
    snapshot->analyzer_warm = 1;
    for (band = 0; band < EQ_UI_ANALYZER_COUNT; band++)
    {
        snapshot->band_pixel[band] = EQ_UI_ANALYZER_ZERO_PIXEL;
    }
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    snapshot->page = EQ_UI_PAGE_DYNAMIC_STATUS;
    snapshot->editor_selected_band = 0;
    snapshot->editor_apply_status = EQ_UI_APPLY_APPLIED;
    snapshot->editor_submitted_valid = 1U;
#endif
}

static void make_healthy_hardware(EQ_LCD_HW_SNAPSHOT *hardware)
{
    memset(hardware, 0, sizeof(*hardware));
    hardware->frame_base = EQ_DebugLcdExpectedFrameBase;
    hardware->frame_end = EQ_DebugLcdExpectedFrameEnd;
    hardware->frame1_base = EQ_DebugLcdExpectedFrameBase;
    hardware->frame1_end = EQ_DebugLcdExpectedFrameEnd;
    hardware->raster_control = 1UL;
}

static int start_display(EQ_UI_SNAPSHOT *snapshot,
                         unsigned int cache_mode)
{
    EQ_LCD_HW_SNAPSHOT hardware;

    EqualizerDisplay_Init();
    EqualizerDisplay_TestSetCacheMode(cache_mode);
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_RequestSnapshot(snapshot, 0UL);
    make_healthy_hardware(&hardware);
    EqualizerDisplay_TestSetHardwareSnapshot(&hardware);
    if (EqualizerDisplay_DrawStaticLayout() != 1)
    {
        return 0;
    }
    EqualizerDisplay_BeginRuntime();
#if EQ_ENABLE_TEN_BAND_EDITOR == 0
    if ((flush_jobs(1UL, 64) < 0) || EqualizerDisplay_HasPendingJob())
    {
        return 0;
    }
#endif
    return 1;
}

static int service_next(unsigned long *frame)
{
    int job;

    job = EqualizerDisplay_ServiceOneJob(*frame);
    (*frame)++;
    return job;
}

static int flush_jobs(unsigned long start_frame, int maximum)
{
    unsigned long frame;
    int count;
    int job;

    frame = start_frame;
    count = 0;
    while (EqualizerDisplay_HasPendingJob() && (count < maximum))
    {
        job = service_next(&frame);
        if (job != EQ_LCD_JOB_NONE)
        {
            count++;
        }
    }
    return count;
}

static int test_cardinality_static_and_cache(void)
{
    EQ_UI_SNAPSHOT snapshot;
    unsigned long primitives;
    unsigned long writebacks;
    int failures;

    failures = 0;
    failures += require_true(
        EQ_DebugLcdCategoryCountSize == EQ_LCD_CATEGORY_COUNT &&
        EQ_DebugLcdJobTypeCountSize == EQ_LCD_JOB_COUNT &&
        EQ_DebugUiJobCountSize == EQ_UI_JOB_COUNT &&
        EQ_DebugDynamicHitboxCountSize == EQ_UI_DYNAMIC_HITBOX_COUNT &&
        EQ_DebugEditorHitboxCountSize == EQ_TEST_EDITOR_HITBOX_COUNT,
        "retained debug cardinalities");
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += require_true(EQ_UI_JOB_COUNT == 25 &&
        EQ_UI_JOB_PAGE_SYNC == 24 && EQ_UI_JOB_PAGE_SWAP == 25 &&
        EQ_LCD_SWAP_TRACE_DEPTH == 64U,
        "editor job and swap trace contracts");
#endif

    make_snapshot(&snapshot);
    failures += require_true(
        start_display(&snapshot, EQ_LCD_CACHE_NONCACHEABLE),
        "noncacheable static layout");
    failures += require_true(
        EQ_DebugLcdCacheMode == EQ_LCD_CACHE_NONCACHEABLE &&
        EQ_DebugLcdWritebackCount == 0UL &&
        EQ_DebugLcdWritebackBytes == 0UL &&
        EQ_DebugLcdWritebackFailureCount == 0UL,
        "noncacheable framebuffer skips writeback");
    failures += require_true(!EqualizerDisplay_HasPendingJob(),
                             "both startup pages are rendered");
    primitives = EqualizerDisplay_TestPrimitiveCount();
    failures += require_true(primitives > 0UL &&
        EQ_DebugLcdBoundsFailureCount == 0UL,
        "static layout has bounded primitives");
    EqualizerDisplay_TestDrawRect(-1, 0, 1, 1);
    failures += require_true(EQ_DebugLcdBoundsFailureCount == 1UL &&
        EqualizerDisplay_TestPrimitiveCount() == primitives,
        "invalid rectangle is rejected before drawing");
    EQ_DebugLcdBoundsFailureCount = 0UL;
    failures += require_true(EqualizerDisplay_DrawStaticLayout() == -1 &&
        EQ_DebugLcdUnexpectedFullRedrawCount == 1UL,
        "runtime rejects full static redraw");

    make_snapshot(&snapshot);
    failures += require_true(
        start_display(&snapshot, EQ_LCD_CACHE_CACHEABLE),
        "cacheable static layout");
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += require_true(EQ_DebugLcdWritebackCount == 2UL,
                             "both permanent pages are written back");
#else
    failures += require_true(EQ_DebugLcdWritebackCount >= 1UL,
                             "single page writes are published");
#endif
    failures += require_true(EQ_DebugLcdWritebackBytes > 0UL &&
        EQ_DebugLcdWritebackFailureCount == 0UL,
        "cacheable writeback publishes real byte count");
    writebacks = EQ_DebugLcdWritebackCount;
    EqualizerDisplay_TestSetCacheMode(EQ_LCD_CACHE_MIXED);
    snapshot.smart_active = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 100UL);
    failures += require_true(flush_jobs(100UL, 16) == 1 &&
        EQ_DebugLcdWritebackCount == writebacks,
        "mixed cache mode does not call writeback");
    return failures;
}

static int test_runtime_bar_and_active(void)
{
    EQ_UI_SNAPSHOT snapshot;
    unsigned long frame;
    unsigned long strip_count;
    int failures;
    int job;

    failures = 0;
    make_snapshot(&snapshot);
    failures += require_true(
        start_display(&snapshot, EQ_LCD_CACHE_NONCACHEABLE),
        "runtime renderer setup");

    snapshot.band_pixel[1] = EQ_UI_ANALYZER_ZERO_PIXEL - 40;
    EqualizerDisplay_RequestSnapshot(&snapshot, 1000UL);
    frame = 1000UL;
    strip_count = EQ_DebugLcdAnalyzerStripCount;
    job = service_next(&frame);
    failures += require_true(job == EQ_UI_JOB_ANALYZER_0 + 1 &&
        EQ_DebugLcdAnalyzerLastField == EQ_UI_ANALYZER_FIELD_BAR &&
        EQ_DebugLcdAnalyzerStripCount == strip_count + 1UL,
        "analyzer runtime draws one bar strip and no dB text");
    failures += require_true(
        EQ_DebugLcdAnalyzerLastStripHeight <=
            EQ_UI_ANALYZER_MAX_STRIP_HEIGHT &&
        EQ_DebugLcdAnalyzerMaxStripHeight <=
            EQ_UI_ANALYZER_MAX_STRIP_HEIGHT,
        "analyzer strip stays bounded");
    failures += require_true(flush_jobs(frame, 16) == 2 &&
        EQ_DebugLcdAnalyzerStripCount == strip_count + 3UL,
        "large analyzer change converges without value field");

    snapshot.smart_active = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 2000UL);
    failures += require_true(flush_jobs(2000UL, 8) == 1 &&
        EQ_DebugLcdLastJob == EQ_UI_JOB_DYNAMIC_0,
        "dynamic ACTIVE indicator is one bounded job");

    snapshot.clarity_active = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 3000UL);
    EqualizerDisplay_TestForceJobCycles(
        EQ_LCD_JOB_ACCEPTANCE_CYCLES + 1UL);
    failures += require_true(
        EqualizerDisplay_ServiceOneJob(3000UL) != EQ_LCD_JOB_NONE &&
        EQ_DebugLcdBudgetExceededCount == 1UL,
        "acceptance budget overrun is recorded");
    EqualizerDisplay_TestForceJobCycles(0UL);

    snapshot.guard_active = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 4000UL);
    EqualizerDisplay_TestForceJobCycles(EQ_LCD_JOB_HARD_CYCLES + 1UL);
    failures += require_true(
        EqualizerDisplay_ServiceOneJob(4000UL) != EQ_LCD_JOB_NONE &&
        EQ_DebugLcdHardBudgetExceededCount == 1UL &&
        EQ_DebugLcdRuntimeMask == 0U &&
        !EqualizerDisplay_HasPendingJob(),
        "hard budget overrun disables and cancels runtime UI");
    EqualizerDisplay_TestForceJobCycles(0UL);
    return failures;
}

#if EQ_ENABLE_TEN_BAND_EDITOR != 0
static int test_permanent_pages_and_swap_trace(void)
{
    EQ_UI_SNAPSHOT snapshot;
    unsigned long frame;
    unsigned long primitives;
    unsigned long writebacks;
    unsigned long swap_jobs_before;
    int failures;
    int job;
    int sync_count;

    failures = 0;
    make_snapshot(&snapshot);
    failures += require_true(
        start_display(&snapshot, EQ_LCD_CACHE_CACHEABLE),
        "permanent page setup");
    primitives = EqualizerDisplay_TestPrimitiveCount();
    writebacks = EQ_DebugLcdWritebackCount;

    snapshot.editor_selected_band = 2;
    snapshot.applied_gain_half_db[2] = 8;
    snapshot.draft_gain_half_db[2] = 8;
    snapshot.editor_draft_version = 1UL;
    EqualizerDisplay_RequestSnapshot(&snapshot, 10UL);
    snapshot.applied_gain_half_db[2] = -6;
    snapshot.draft_gain_half_db[2] = -6;
    snapshot.editor_draft_version = 2UL;
    EqualizerDisplay_RequestSnapshot(&snapshot, 11UL);
    failures += require_true(!EqualizerDisplay_HasPendingJob() &&
        EQ_DebugLcdEditorDirtyMask != 0UL &&
        EQ_DebugLcdDynamicDirtyMask == 0UL &&
        EqualizerDisplay_TestPrimitiveCount() == primitives &&
        EQ_DebugLcdWritebackCount == writebacks,
        "hidden editor is latest-wins and not drawn eagerly");

    snapshot.page = EQ_UI_PAGE_EQ_EDITOR;
    EqualizerDisplay_RequestSnapshot(&snapshot, 20UL);
    failures += require_true(EqualizerDisplay_IsPageBuilding() &&
        EQ_DebugLcdPagePhase == EQ_UI_PAGE_PHASE_SYNC &&
        EqualizerDisplay_GetDisplayedPage() ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "page request enters PAGE_SYNC");
    frame = 20UL;
    sync_count = 0;
    while ((EQ_DebugLcdPagePhase == EQ_UI_PAGE_PHASE_SYNC) &&
           (EQ_DebugLcdEditorDirtyMask != 0UL) &&
           (sync_count < 64))
    {
        job = service_next(&frame);
        if (job == EQ_UI_JOB_PAGE_SYNC)
        {
            sync_count++;
        }
    }
    failures += require_true(sync_count > 0 &&
        EQ_DebugLcdEditorDirtyMask == 0UL &&
        EQ_DebugLcdPagePhase == EQ_UI_PAGE_PHASE_SYNC &&
        EqualizerDisplay_GetDisplayedPage() ==
            EQ_UI_PAGE_DYNAMIC_STATUS &&
        EQ_DebugLcdSwapRequestCount == 0UL,
        "last PAGE_SYNC leaves swap for next service boundary");
    failures += require_true(EQ_DebugLcdWritebackCount > writebacks &&
        EQ_DebugLcdWritebackFailureCount == 0UL,
        "hidden dirty regions are written back before swap");

    swap_jobs_before =
        EQ_DebugLcdJobTypeCount[EQ_UI_JOB_PAGE_SWAP - 1];
    do
    {
        job = service_next(&frame);
    }
    while (job == EQ_LCD_JOB_NONE);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EQ_DebugLcdSwapPending == 1U &&
        EQ_DebugLcdSwapDescriptorMask == 0U &&
        EQ_DebugLcdSwapRequestCount == 1UL &&
        EqualizerDisplay_GetDisplayedPage() ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "first PAGE_SWAP call only publishes pending request");
    do
    {
        job = service_next(&frame);
    }
    while (job == EQ_LCD_JOB_NONE);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EQ_DebugLcdSwapPending == 1U &&
        EQ_DebugLcdSwapDescriptorMask == 1U &&
        EqualizerDisplay_GetDisplayedPage() ==
            EQ_UI_PAGE_DYNAMIC_STATUS,
        "first EOF updates one descriptor without changing page");
    do
    {
        job = service_next(&frame);
    }
    while (job == EQ_LCD_JOB_NONE);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EQ_DebugLcdSwapPending == 0U &&
        EQ_DebugLcdSwapDescriptorMask == 3U &&
        EQ_DebugLcdSwapCompleteCount == 1UL &&
        EqualizerDisplay_GetDisplayedPage() == EQ_UI_PAGE_EQ_EDITOR &&
        EQ_DebugLcdPagePhase == EQ_UI_PAGE_PHASE_IDLE,
        "second EOF completes descriptor convergence and page swap");
    failures += require_true(
        EQ_DebugLcdJobTypeCount[EQ_UI_JOB_PAGE_SWAP - 1] ==
            swap_jobs_before + 3UL &&
        EQ_DebugLcdSwapTraceCount == 3U &&
        EQ_DebugLcdSwapTrace[0].eof_mask == 0UL &&
        EQ_DebugLcdSwapTrace[0].descriptor_mask == 0U &&
        EQ_DebugLcdSwapTrace[1].eof_mask != 0UL &&
        EQ_DebugLcdSwapTrace[1].descriptor_mask == 1U &&
        EQ_DebugLcdSwapTrace[2].eof_mask != 0UL &&
        EQ_DebugLcdSwapTrace[2].descriptor_mask == 3U &&
        EQ_DebugLcdSwapTrace[2].swap_complete == 1U,
        "swap ring records request and both EOF boundaries");
    failures += require_true(
        EQ_DebugLcdPageRenderedVersion[EQ_UI_PAGE_EQ_EDITOR] ==
            EQ_DebugLcdPageRequestedVersion[EQ_UI_PAGE_EQ_EDITOR],
        "editor rendered version catches latest requested version");

    snapshot.page = EQ_UI_PAGE_DYNAMIC_STATUS;
    EqualizerDisplay_RequestSnapshot(&snapshot, 1000UL);
    frame = 1000UL;
    do
    {
        job = service_next(&frame);
    }
    while (job == EQ_LCD_JOB_NONE);
    failures += require_true(job == EQ_UI_JOB_PAGE_SWAP &&
        EQ_DebugLcdPagePhase == EQ_UI_PAGE_PHASE_SWAP &&
        EQ_DebugLcdDynamicDirtyMask == 0UL,
        "clean permanent page skips PAGE_SYNC data work");
    return failures;
}

static int test_swap_ring_wrap(void)
{
    unsigned int index;
    int failures;

    failures = 0;
    EqualizerDisplay_Init();
    for (index = 0U; index < EQ_LCD_SWAP_TRACE_DEPTH + 6U; index++)
    {
        EqualizerDisplay_TestInjectEofStatus(
            ((index & 1U) == 0U) ? 0x100UL : 0x200UL);
    }
    failures += require_true(
        EQ_DebugLcdSwapTraceCount == EQ_LCD_SWAP_TRACE_DEPTH &&
        EQ_DebugLcdSwapTraceWriteIndex == 6U &&
        EQ_DebugLcdSwapTraceWrapCount == 6UL &&
        EQ_DebugLcdEofCount == EQ_LCD_SWAP_TRACE_DEPTH + 6UL &&
        EQ_DebugLcdEofAmbiguousCount == 0UL &&
        EQ_DebugLcdFaultLatched == 0U,
        "64-depth swap ring overwrites oldest entries without fault");
    return failures;
}
#endif

static int test_hardware_fault_contract(void)
{
    EQ_LCD_HW_SNAPSHOT hardware;
    int failures;

    failures = 0;
    EqualizerDisplay_Init();
    make_healthy_hardware(&hardware);
    EqualizerDisplay_TestSetHardwareSnapshot(&hardware);
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_AuditHardware(100UL, 1);
    failures += require_true(EQ_DebugLcdFaultLatched == 0U &&
        EQ_DebugLcdCurrentFrameBase == EQ_DebugLcdExpectedFrameBase &&
        EQ_DebugLcdCurrentFrame1Base == EQ_DebugLcdExpectedFrameBase,
        "healthy hardware audit");

    hardware.raster_status = 0x20UL;
    EqualizerDisplay_TestSetHardwareSnapshot(&hardware);
    EqualizerDisplay_AuditHardware(101UL, 1);
    failures += require_true(EQ_DebugLcdFaultLatched == 1U &&
        EQ_DebugLcdFifoUnderflowCount == 1UL &&
        EQ_DebugLcdRasterFaultCount == 1UL &&
        EQ_DebugLcdRuntimeMask == 0U,
        "fifo underflow fails closed");

    EqualizerDisplay_Init();
    make_healthy_hardware(&hardware);
    hardware.frame_base = EQ_DebugLcdExpectedFrameBase + 4UL;
    EqualizerDisplay_TestSetHardwareSnapshot(&hardware);
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_AuditHardware(200UL, 1);
    failures += require_true(
        EQ_DebugLcdFrameAddressMismatchCount == 1UL &&
        EQ_DebugLcdFaultLatched == 1U &&
        EQ_DebugLcdRuntimeMask == 0U,
        "frame address mismatch fails closed");

    EqualizerDisplay_Init();
    make_healthy_hardware(&hardware);
    EqualizerDisplay_TestSetHardwareSnapshot(&hardware);
    EqualizerDisplay_TestSetCanaryFailure(1);
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_AuditHardware(300UL, 1);
    failures += require_true(
        EQ_DebugLcdFramebufferCanaryFailureCount == 1UL &&
        EQ_DebugLcdFramebufferFirstFailureFrame == 300UL &&
        EQ_DebugLcdFaultLatched == 1U &&
        EQ_DebugLcdRuntimeMask == 0U,
        "framebuffer canary failure fails closed");
    return failures;
}

int main(void)
{
    int failures;

    failures = 0;
    failures += test_cardinality_static_and_cache();
    failures += test_runtime_bar_and_active();
#if EQ_ENABLE_TEN_BAND_EDITOR != 0
    failures += test_permanent_pages_and_swap_trace();
    failures += test_swap_ring_wrap();
#endif
    failures += test_hardware_fault_contract();
    printf("equalizer_display failures=%d\n", failures);
    return (failures == 0) ? 0 : 1;
}
