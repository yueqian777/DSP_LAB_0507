#include "user_equalizer_display.h"

#include <stdio.h>
#include <string.h>

static int require_true(int condition, const char *message)
{
    if (!condition)
    {
        printf("equalizer_display FAIL: %s\n", message);
        return 1;
    }
    return 0;
}

static void make_snapshot(EQ_UI_SNAPSHOT *snapshot)
{
    int band;

    memset(snapshot, 0, sizeof(*snapshot));
    snapshot->applied_preset = EQ_PRESET_FLAT;
    snapshot->smart_strength = 2;
    snapshot->clarity_strength = 2;
    snapshot->guard_strength = 2;
    snapshot->analyzer_valid = 1;
    snapshot->analyzer_warm = 1;
    for (band = 0; band < EQ_UI_ANALYZER_COUNT; band++)
    {
        snapshot->band_pixel[band] = EqualizerUi_DbTenthsToPixel(0);
    }
}

static int flush_jobs(unsigned long frame)
{
    int count;
    int job;

    count = 0;
    while (EqualizerDisplay_HasPendingJob() && (count < 64))
    {
        job = EqualizerDisplay_ServiceOneJob(frame + (unsigned long)count);
        if (job == EQ_LCD_JOB_NONE)
        {
            return -1;
        }
        count++;
    }
    return count;
}

int main(void)
{
    EQ_UI_SNAPSHOT snapshot;
    unsigned long primitives;
    unsigned long unexpected;
    int failures;
    int job;

    failures = 0;
    EqualizerDisplay_Init();
    failures += require_true(EqualizerDisplay_DrawStaticLayout() == 1,
                             "first static draw");
    primitives = EqualizerDisplay_TestPrimitiveCount();
    failures += require_true(primitives > 0UL, "static primitives");
    failures += require_true(EQ_DebugLcdBoundsFailureCount == 0UL,
                             "static bounds");
    failures += require_true(EqualizerDisplay_DrawStaticLayout() == 0,
                             "static draw idempotent");

    make_snapshot(&snapshot);
    EQ_DebugLcdRuntimeMask = EQ_UI_RUNTIME_ALL;
    EqualizerDisplay_RequestSnapshot(&snapshot, 1UL);
    failures += require_true(
        EqualizerDisplay_TestPrimitiveCount() == primitives,
        "request does not draw");
    failures += require_true(EqualizerDisplay_HasPendingJob(),
                             "snapshot creates jobs");
    job = EqualizerDisplay_ServiceOneJob(1UL);
    failures += require_true(job != EQ_LCD_JOB_NONE,
                             "service one job");
    failures += require_true(EQ_DebugLcdJobCount == 1UL,
                             "one service one count");
    failures += require_true(flush_jobs(2UL) == EQ_LCD_JOB_COUNT - 1,
                             "remaining jobs bounded");
    failures += require_true(EQ_DebugLcdBoundsFailureCount == 0UL,
                             "runtime bounds");

    EqualizerDisplay_BeginRuntime();
    unexpected = EQ_DebugLcdUnexpectedFullRedrawCount;
    primitives = EqualizerDisplay_TestPrimitiveCount();
    failures += require_true(EqualizerDisplay_DrawStaticLayout() == -1,
                             "runtime rejects static draw");
    failures += require_true(
        EQ_DebugLcdUnexpectedFullRedrawCount == unexpected + 1UL,
        "unexpected redraw counter");
    failures += require_true(
        EqualizerDisplay_TestPrimitiveCount() == primitives,
        "rejected static draw has no primitives");

    snapshot.applied_preset = EQ_PRESET_BASS_BOOST;
    EqualizerDisplay_RequestSnapshot(&snapshot, 30UL);
    failures += require_true(flush_jobs(30UL) == 2,
                             "preset old and new jobs");

    snapshot.band_pixel[1] = EqualizerUi_DbTenthsToPixel(100);
    snapshot.band_value_db[1] = 10;
    EqualizerDisplay_RequestSnapshot(&snapshot, 40UL);
    failures += require_true(flush_jobs(40UL) == 1,
                             "single analyzer job");

    snapshot.smart_level = 2;
    EqualizerDisplay_RequestSnapshot(&snapshot, 50UL);
    failures += require_true(flush_jobs(50UL) == 1,
                             "single dynamic row job");

    snapshot.clarity_level = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 60UL);
    EqualizerDisplay_TestForceJobCycles(EQ_LCD_JOB_TARGET_CYCLES + 1UL);
    failures += require_true(EqualizerDisplay_ServiceOneJob(60UL) !=
                             EQ_LCD_JOB_NONE, "timed warning job");
    failures += require_true(EQ_DebugLcdBudgetExceededCount == 1UL,
                             "two ms warning");

    snapshot.guard_level = 1;
    EqualizerDisplay_RequestSnapshot(&snapshot, 70UL);
    EqualizerDisplay_TestForceJobCycles(EQ_LCD_JOB_HARD_CYCLES + 1UL);
    failures += require_true(EqualizerDisplay_ServiceOneJob(70UL) !=
                             EQ_LCD_JOB_NONE, "timed hard job");
    failures += require_true(EQ_DebugLcdHardBudgetExceededCount == 1UL,
                             "five ms failure");
    failures += require_true(EQ_DebugLcdRuntimeMask == 0U,
                             "hard job disables runtime");
    failures += require_true(!EqualizerDisplay_HasPendingJob(),
                             "hard job cancels pending");

    printf("equalizer_display failures=%d\n", failures);
    return (failures == 0) ? 0 : 1;
}
